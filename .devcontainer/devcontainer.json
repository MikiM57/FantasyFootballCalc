{
  "name": "Fantasy Edge AI",
  "image": "mcr.microsoft.com/devcontainers/python:1-3.11-bookworm",
  "postCreateCommand": "pip install -e '.[dev,api]'",
  "forwardPorts": [8000],
  "portsAttributes": {
    "8000": {
      "label": "Fantasy Edge AI",
      "onAutoForward": "notify"
    }
  },
  "customizations": {
    "vscode": {
      "extensions": ["ms-python.python"]
    }
  }
}
